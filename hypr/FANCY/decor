decoration {
    rounding = 8

    # Holographic Opacity
    active_opacity = 0.95
    inactive_opacity = 0.7
    fullscreen_opacity = 1.0

    shadow {
        enabled = true
        range = 90
        render_power = 4
        color = rgba(00f2ff44)           #Cyan glow for sci-fi
        color_inactive = rgba(1a1a1aee)
        
        # This makes the glow spread outward like a halo
        scale = 1.0

        ignore_window = true
    }

    # Blur settings
    blur {
        enabled = true
        size = 10
        passes = 4
        vibrancy = 0.5
    }
}
