[general]
# High-speed data look
framerate = 60
autosens = 1
# More bars = more detail for the "visor" look
bars = 0
bar_width = 1
bar_spacing = 1

[input]
# Ensure this matches your audio system (usually pipewire or pulse)
method = pipewire
source = auto

[output]
# 'ncurses' is standard for terminal; 'sdl' is for a separate window
method = ncurses

[color]
# Enable the gradient mode
gradient = 1

# Neon Cyan to Hot Pink/Magenta
# These are hex codes; ensure your terminal supports 24-bit color
gradient_count = 8
gradient_color_1 = '#00fefc'
gradient_color_2 = '#00b8ff'
gradient_color_3 = '#001eff'
gradient_color_4 = '#8084ee'
gradient_color_5 = '#bd00ff'
gradient_color_6 = '#d600ff'
gradient_color_7 = '#ff00fe'
gradient_color_8 = '#ff007c'

[smoothing]
# Monstercat smoothing makes the bars look fluid and organic
monstercat = 1
waves = 0
# Lower gravity makes the bars "hang" in the air slightly longer (dreamy feel)
gravity = 100
# Integral smoothing filters out jitter
integral = 70
